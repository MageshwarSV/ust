package com.healthproof.intplus.awscost.excel;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.ApplicationContext;
import org.springframework.stereotype.Service;

@Service
public class ExcelProcessorFactory {
    @Autowired
    private ApplicationContext context;

    public BaseExcelProcessor getProcessor(String companyName) {
        String beanName = companyName.toLowerCase() + "ExcelProcessor";
        try {
            return (BaseExcelProcessor) context.getBean(beanName);
        } catch (Exception e) {
            System.out.println("No specific processor found for " + companyName + ". Using default.");
            return (BaseExcelProcessor) context.getBean("defaultExcelProcessor");
        }
    }
}

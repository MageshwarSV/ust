    .header h1{font-size:2.5rem;letter-spacing:2px;background:linear-gradient(90deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    .header p{color:#94a3b8;margin-top:8px}
    
    .controls-bar{display:flex;flex-wrap:wrap;gap:15px;align-items:center;justify-content:center;background:rgba(255,255,255,.03);border:1px solid var(--card-border);backdrop-filter:blur(10px);padding:15px 25px;border-radius:16px;margin-bottom:30px;width:100%;max-width:900px}
    select{background:rgba(255,255,255,.07);border:1px solid var(--card-border);border-radius:8px;color:#fff;padding:10px 16px;font-size:.95rem;outline:none;cursor:pointer;transition:all .3s}
    select:hover{background:rgba(255,255,255,.12);border-color:var(--primary)}
    option{background:#1e1b4b;color:#fff}
    
    .btn{padding:10px 20px;border-radius:8px;font-weight:600;font-size:.95rem;cursor:pointer;transition:all .3s;border:1px solid transparent}
    .btn-secondary{background:rgba(255,255,255,.05);border-color:var(--card-border);color:#e5e7eb}
    .btn-secondary:hover{background:rgba(255,255,255,.1);border-color:#9ca3af}
    .btn-primary{background:linear-gradient(90deg,var(--primary),var(--secondary));color:#fff;box-shadow:0 4px 14px rgba(167,139,250,.3)}
    .btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 6px 20px rgba(167,139,250,.45)}
    .btn-primary:disabled{opacity:.4;cursor:not-allowed;box-shadow:none}
    
    .buttons-container{display:flex;flex-wrap:wrap;gap:20px;justify-content:center;max-width:900px;width:100%;margin-bottom:30px}
    .company-card{position:relative;background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:35px 25px;text-align:center;cursor:pointer;transition:all .3s cubic-bezier(.4,0,.2,1);min-width:200px;backdrop-filter:blur(10px);user-select:none}
    .company-card:hover{background:var(--card-hover-bg);border-color:rgba(167,139,250,.4);transform:translateY(-4px)}
    .company-card.selected{background:var(--card-selected-bg);border-color:var(--card-selected-border);box-shadow:0 0 20px rgba(167,139,250,.25)}
    
    .card-checkbox{position:absolute;top:15px;right:15px;width:22px;height:22px;border-radius:6px;border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;transition:all .2s;background:rgba(0,0,0,.2)}
    .company-card.selected .card-checkbox{background:var(--primary);border-color:var(--primary)}
    .card-checkbox::after{content:'';width:5px;height:10px;border:solid #fff;border-width:0 2px 2px 0;transform:rotate(45deg);display:none;margin-bottom:2px}
    .company-card.selected .card-checkbox::after{display:block}
    
    .company-name{font-size:1.6rem;font-weight:700;color:#fff;margin-bottom:10px}
    .company-card.selected .company-name{color:#a78bfa}
    
    .status-badge{font-size:.8rem;padding:4px 12px;border-radius:12px;display:inline-block;font-weight:600;background:rgba(255,255,255,.05);color:#9ca3af;margin-top:10px}
    .status-badge.idle{display:none}
    .status-badge.generating{background:rgba(245,158,11,.15);color:#f59e0b;border:1px solid rgba(245,158,11,.3)}
    .status-badge.completed{background:rgba(16,185,129,.15);color:#10b981;border:1px solid rgba(16,185,129,.3)}
    .status-badge.failed{background:rgba(239,68,68,.15);color:#ef4444;border:1px solid rgba(239,68,68,.3)}
    
    .spinner{display:inline-block;width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#a78bfa;border-radius:50%;animation:spin .8s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    
    .status-box{margin-top:20px;max-width:900px;width:100%;border-radius:12px;padding:20px 24px;display:none}
    .status-box.active{display:block;background:rgba(255,255,255,.03);border:1px solid var(--card-border)}
    .log-entry{margin-bottom:8px;font-family:monospace;font-size:.9rem;display:flex;align-items:center;gap:10px}
    .log-success{color:#34d399}
    .log-error{color:#f87171}
    .log-info{color:#60a5fa}
    .download-link{color:#60a5fa;text-decoration:underline;cursor:pointer}
    .loading-msg{color:#94a3b8;margin-top:30px;font-size:.9rem}
  </style>
</head>
<body>
  <div class="header"><h1>USTHP AWS Cost Report</h1><p>Select companies to generate and download monthly cost reports</p></div>
  
  <div class="controls-bar">
    <select id="companyFilter"><option value="ALL">All Accounts</option></select>
    <select id="monthSelect"></select>
    <button class="btn btn-secondary" id="btnSelectAll">Select All</button>
    <button class="btn btn-secondary" id="btnDeselectAll">Clear</button>
    <button class="btn btn-primary" id="btnGenerate" disabled>Generate Selected (0)</button>
  </div>

  <div class="buttons-container" id="bc"><p class="loading-msg">Loading companies...</p></div>
  <div class="status-box" id="sb"></div>

  <script>
    let allProfiles = [];
    let selectedCompanies = new Set();
    let cardStatuses = {};

    function populateMonths() {
      const monthSelect = document.getElementById('monthSelect');
      monthSelect.innerHTML = '';
      
      const defOpt = document.createElement('option');
      defOpt.value = 'DEFAULT';
      defOpt.textContent = 'Default (Previous Month)';
      defOpt.selected = true;
      monthSelect.appendChild(defOpt);

      const now = new Date();
      for (let i = 1; i <= 12; i++) {
        const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
        const opt = document.createElement('option');
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        opt.value = `${year}-${month}`;
        const monthName = d.toLocaleString('default', { month: 'long' });
        opt.textContent = `${monthName} ${year}`;
        monthSelect.appendChild(opt);
      }
    }

    async function load() {
      try {
        populateMonths();
        const res = await fetch('/awscost/api/profiles');
        allProfiles = await res.json();
        
        const filterSelect = document.getElementById('companyFilter');
        filterSelect.innerHTML = '<option value="ALL">All Accounts</option>';
        allProfiles.forEach(p => {
          const opt = document.createElement('option');
          opt.value = p.companyName;
          opt.textContent = p.companyName;
          filterSelect.appendChild(opt);
        });

        allProfiles.forEach(p => {
          if (!cardStatuses[p.companyName]) {
            cardStatuses[p.companyName] = { status: 'idle', msg: 'Idle' };
          }
        });

        render();
      } catch (e) {
        document.getElementById('bc').innerHTML = '<p class="loading-msg" style="color:#f87171">Failed to load profiles.</p>';
      }
    }

    function render() {
      const container = document.getElementById('bc');
      container.innerHTML = '';
      
      const filterVal = document.getElementById('companyFilter').value;

      let list = allProfiles;
      if (filterVal !== 'ALL') {
        list = allProfiles.filter(p => p.companyName === filterVal);
      }

      list.sort((a, b) => a.companyName.localeCompare(b.companyName));

      if (!list.length) {
        container.innerHTML = '<p class="loading-msg">No companies found.</p>';
        return;
      }

      list.forEach(p => {
        const card = document.createElement('div');
        card.className = 'company-card' + (selectedCompanies.has(p.companyName) ? ' selected' : '');
        
        const stateObj = cardStatuses[p.companyName] || { status: 'idle', msg: 'Idle' };
        let statusBadgeClass = 'status-badge';
        let statusText = stateObj.msg;
        if (stateObj.status === 'generating') {
          statusBadgeClass += ' generating';
          statusText = '<div class="spinner" style="margin-right:5px; vertical-align:middle"></div> Generating...';
        } else if (stateObj.status === 'completed') {
          statusBadgeClass += ' completed';
        } else if (stateObj.status === 'failed') {
          statusBadgeClass += ' failed';
        } else {
          statusBadgeClass += ' idle';
        }

        card.innerHTML = `
          <div class="card-checkbox"></div>
          <div class="company-name">${p.companyName}</div>
          <div class="${statusBadgeClass}">${statusText}</div>
        `;

        card.onclick = (e) => {
          if (stateObj.status === 'generating') return;
          toggleSelect(p.companyName);
        };

        container.appendChild(card);
      });

      updateGenerateButton();
    }

    function toggleSelect(name) {
      if (selectedCompanies.has(name)) {
        selectedCompanies.delete(name);
      } else {
        selectedCompanies.add(name);
      }
      render();
    }

    function updateGenerateButton() {
      const btn = document.getElementById('btnGenerate');
      btn.textContent = `Generate Selected (${selectedCompanies.size})`;
      btn.disabled = selectedCompanies.size === 0;
    }

    document.getElementById('btnSelectAll').onclick = () => {
      const filterVal = document.getElementById('companyFilter').value;
      const list = filterVal === 'ALL' ? allProfiles : allProfiles.filter(p => p.companyName === filterVal);
      list.forEach(p => {
        if (cardStatuses[p.companyName].status !== 'generating') {
          selectedCompanies.add(p.companyName);
        }
      });
      render();
    };

    document.getElementById('btnDeselectAll').onclick = () => {
      selectedCompanies.clear();
      render();
    };

    document.getElementById('companyFilter').onchange = () => {
      selectedCompanies.clear();
      render();
    };

    document.getElementById('btnGenerate').onclick = async () => {
      const sb = document.getElementById('sb');
      sb.className = 'status-box active';
      sb.innerHTML = '<h3>Execution Logs</h3><hr style="margin:10px 0; border-color:rgba(255,255,255,.1)"/>';
      
      const toGenerate = Array.from(selectedCompanies);
      document.querySelectorAll('.controls-bar button, .controls-bar select').forEach(el => el.disabled = true);

      for (const compName of toGenerate) {
        const profile = allProfiles.find(p => p.companyName === compName);
        if (!profile) continue;

        cardStatuses[compName] = { status: 'generating', msg: 'Generating...' };
        render();

        const logRow = document.createElement('div');
        logRow.className = 'log-entry log-info';
        logRow.innerHTML = `<div class="spinner"></div> Processing <strong>${compName}</strong>...`;
        sb.appendChild(logRow);

        try {
          const res = await fetch('/awscost/api/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              companyName: profile.companyName,
              environments: profile.environments,
              profiles: profile.profiles,
              yearMonth: document.getElementById('monthSelect').value
            })
          });
          const data = await res.json();

          if (data.status === 'success') {
            cardStatuses[compName] = { status: 'completed', msg: 'Completed' };
            logRow.className = 'log-entry log-success';
            logRow.innerHTML = `&#10004; <strong>${compName}</strong> report generated successfully: <a class="download-link" href="/awscost/downloads/${data.fileName}" download>${data.fileName}</a>`;
            
            const link = document.createElement('a');
            link.href = '/awscost/downloads/' + data.fileName;
            link.download = data.fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
          } else {
            throw new Error(data.message || 'Generation failed');
          }
        } catch (e) {
          cardStatuses[compName] = { status: 'failed', msg: 'Failed' };
          logRow.className = 'log-entry log-error';
          logRow.innerHTML = `&#10007; <strong>${compName}</strong> failed: ${e.message}`;
        }
        render();
      }

      document.querySelectorAll('.controls-bar button, .controls-bar select').forEach(el => el.disabled = false);
      updateGenerateButton();
    };

    load();
  </script>
</body>
</html>

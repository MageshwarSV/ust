package com.healthproof.intplus.awscost.excel;
import com.healthproof.intplus.awscost.Model;
import com.healthproof.intplus.awscost.util.ExcelMapper;
import org.apache.poi.ss.usermodel.*;
import org.apache.poi.ss.util.CellReference;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import java.io.*;
import java.math.*;
import java.nio.file.*;
import java.text.SimpleDateFormat;
import java.util.*;
import static com.healthproof.intplus.awscost.util.DateUtil.getRequiredDate;
@Service
public class AdvancedExcelProcessor {
    @Value("${excel.template.file.path}") private String templateFilePath;
    @Value("${excel.template.file.name}") private String templateFileName;
    @Value("${excel.input.file.path}") private String inputFilePath;
    @Value("${excel.input.file.name}") private String inputFileName;
    @Value("${excel.output.file.path}") private String outFilePath;
    private Workbook workbook; private Sheet sheet; private String fileName;
    
    public void start(String companyName, List<String> environments, List<Model> models, String monthYearName) throws IOException {
        String basePattern = "USTHP_" + companyName + "_AWS_SERVICE_COST_" + monthYearName + "-V";
        File outputDir = new File(outFilePath);
        if (!outputDir.exists()) outputDir.mkdirs();
        File[] existing = outputDir.listFiles((d, n) -> n.startsWith(basePattern) && n.endsWith(ExcelMapper.FILE_EXTENSION));
        int version = 1;
        if (existing != null) {
            for (File f : existing) {
                try {
                    String vPart = f.getName().substring(basePattern.length(), f.getName().length() - ExcelMapper.FILE_EXTENSION.length());
                    int x = Integer.parseInt(vPart);
                    if (x >= version) version = x + 1;
                } catch (Exception ignored) {}
            }
        }
        this.fileName = basePattern + version + ExcelMapper.FILE_EXTENSION;
        
        String tplPath = templateFilePath + File.separator + companyName.toLowerCase() + "_template.xlsx";
        File tplFile = new File(tplPath);
        if (!tplFile.exists()) tplPath = templateFilePath + File.separator + templateFileName + ExcelMapper.FILE_EXTENSION;
        try (FileInputStream fis = new FileInputStream(tplPath)) { this.workbook = new XSSFWorkbook(fis); }

        for (int i = 0; i < environments.size(); i++) {
            String env = environments.get(i); Model model = models.get(i);
            String sheetName = companyName + "-" + env;
            sheet = workbook.getSheet(sheetName);
            if (sheet == null) {
                for(int s=0; s<workbook.getNumberOfSheets(); s++){
                    if(workbook.getSheetName(s).equalsIgnoreCase(sheetName)){ sheet = workbook.getSheetAt(s); break; }
                }
            }
            if (sheet == null) { System.out.println("Sheet not found: "+sheetName); continue; }
            
            initSheet(companyName, env);
            writeH4H5(model.getModelMapH4H5(), companyName, env);
            writeR12(model.getModelMapR12(), companyName, env);
            writeR14(model.getModelMapR14(), companyName, env);
            writeR13(model.getModelMapR13(), companyName, env);
            writeESPCost();
        }
        writeExcel(); copyFileToInputDirectory();
    }
    
    // FIX 1: Ignore case so AmeriBen matches perfectly
    private boolean check(String c,String e){return sheet!=null&&sheet.getSheetName().equalsIgnoreCase(c+"-"+e);}
    
    private void initSheet(String c,String e){
        if(!check(c,e))return;
        setStr("H3",getRequiredDate());setNum("H4",0);setNum("H5",0);setNum("H6",0);
        for(int i=1;i<27;i++){
            if(sheet.getRow(11)!=null && sheet.getRow(11).getCell(i)!=null) sheet.getRow(11).getCell(i).setCellValue(0);
            if(sheet.getRow(12)!=null && sheet.getRow(12).getCell(i)!=null) sheet.getRow(12).getCell(i).setCellValue(0);
            if(sheet.getRow(13)!=null && sheet.getRow(13).getCell(i)!=null) sheet.getRow(13).getCell(i).setCellValue(0);
        }
    }
    
    // FIX 2: Correct logic using exactly what AWS API outputs (Usage + Tax)
    public void writeH4H5(Map m,String c,String e){
        if(!check(c,e))return;
        double tax = bd(val(m,"Tax"));
        setNum("H4", bd(val(m,ExcelMapper.H4)) + tax);
        setNum("H5", bd(val(m,ExcelMapper.H5)));
    }
    
    public void writeR12(Map m,String c,String e){
        if(!check(c,e))return;
        setNum("B12",bd(val(m,ExcelMapper.B12)));setNum("C12",bd(val(m,ExcelMapper.C12)));setNum("D12",bd(val(m,ExcelMapper.D12)));
        setNum("H12",bd(val(m,ExcelMapper.H12)));setNum("I12",bd(val(m,ExcelMapper.I12)));setNum("J12",bd(val(m,ExcelMapper.J12)));
        setNum("K12",bd(val(m,ExcelMapper.K12)));setNum("N12",bd(val(m,ExcelMapper.N12)));setNum("O12",bd(val(m,ExcelMapper.O12)));
        setNum("P12",bd(val(m,ExcelMapper.P12)));setNum("Q12",bd(val(m,ExcelMapper.Q12)));setNum("R12",bd(val(m,ExcelMapper.R12)));
        setNum("S12",bd(val(m,ExcelMapper.S12)));setNum("T12",bd(val(m,ExcelMapper.T12)));setNum("U12",bd(val(m,ExcelMapper.U12)));
        if(c.equalsIgnoreCase("IBX")&&e.equalsIgnoreCase("PROD"))setNum("U12",bd(val(m,ExcelMapper.U12_1)));
        setNum("V12",bd(val(m,ExcelMapper.V12)));
    }
    public void writeR14(Map m,String c,String e){if(!check(c,e))return;setNum("W12",bd(val(m,ExcelMapper.W12)));setNum("Y12",bd(val(m,ExcelMapper.Y12)));}
    
    public void writeR13(Map m,String c,String e){
        if(!check(c,e))return;
        setNum("B13",bd(val(m,ExcelMapper.B13)));setNum("C13",bd(val(m,ExcelMapper.C13)));setNum("D13",bd(val(m,ExcelMapper.D13)));
        setNum("H13",bd(val(m,ExcelMapper.H13)));setNum("I13",bd(val(m,ExcelMapper.I13)));setNum("J13",bd(val(m,ExcelMapper.J13)));
        setNum("K13",bd(val(m,ExcelMapper.K13)));setNum("N13",bd(val(m,ExcelMapper.N13)));setNum("O13",bd(val(m,ExcelMapper.O13)));
        setNum("P13",bd(val(m,ExcelMapper.P13)));setNum("Q13",bd(val(m,ExcelMapper.Q13)));setNum("Y13",bd(val(m,ExcelMapper.Y13)));
        if(c.equalsIgnoreCase("IBX")&&e.equalsIgnoreCase("CS"))setNum("W13",bd(val(m,ExcelMapper.W13)));
    }
    private void writeESPCost(){setNum("H6",0);setNum("AA12",0);}
    private double bd(String v){return new BigDecimal(v).setScale(2,RoundingMode.HALF_UP).doubleValue();}
    private String val(Map<String,String> m,String k){return m.get(k)!=null?m.get(k).toString():"0";}
    private void setNum(String ref, double val) {
        Cell c = getCell(ref);
        if (c != null) { c.setCellValue(val); }
    }
    private void setStr(String ref, String val) {
        Cell c = getCell(ref);
        if (c != null) c.setCellValue(val);
    }
    private Cell getCell(String ref) {
        CellReference cr = new CellReference(ref);
        Row r = sheet.getRow(cr.getRow());
        if (r == null) r = sheet.createRow(cr.getRow());
        Cell c = r.getCell(cr.getCol());
        if (c == null) c = r.createCell(cr.getCol());
        return c;
    }
    
    // FIX 3: Force Java and Excel to recalculate formulas so Total Cost never shows $0.00!
    private void writeExcel() throws IOException {
        FormulaEvaluator evaluator = workbook.getCreationHelper().createFormulaEvaluator();
        evaluator.evaluateAll();
        workbook.setForceFormulaRecalculation(true);
        try (FileOutputStream fos = new FileOutputStream(outFilePath + File.separator + fileName)) { 
            workbook.write(fos); 
            workbook.close(); 
        }
    }
    
    private void copyFileToInputDirectory() throws IOException {
        Path dest = Paths.get(inputFilePath + File.separator + inputFileName + ExcelMapper.FILE_EXTENSION);
        if (Files.notExists(dest)) Files.createFile(dest);
        Files.copy(Paths.get(outFilePath + File.separator + fileName), dest, StandardCopyOption.REPLACE_EXISTING);
    }
    public String getFileName() { return fileName; }
}

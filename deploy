package com.healthproof.intplus.awscost;
import org.springframework.stereotype.Service;
import java.io.*;
import java.util.*;
@Service
public class CredentialsReader {
    private String getCredentialsFilePath() {
        return System.getProperty("user.home") + File.separator + ".aws" + File.separator + "credentials";
    }
    public List<CompanyProfile> readProfiles() throws IOException {
        Map<String, Map<String, String>> raw = new LinkedHashMap<>();
        String cur = null;
        try (BufferedReader r = new BufferedReader(new FileReader(getCredentialsFilePath()))) {
            String line;
            while ((line = r.readLine()) != null) {
                line = line.trim();
                if (line.startsWith("[") && line.endsWith("]")) {
                    cur = line.substring(1, line.length() - 1);
                    raw.put(cur, new LinkedHashMap<>());
                } else if (cur != null && line.contains("=")) {
                    String[] p = line.split("=", 2);
                    raw.get(cur).put(p[0].trim().toLowerCase(), p[1].trim());
                }
            }
        }
        Map<String, CompanyProfile> grouped = new LinkedHashMap<>();
        for (Map.Entry<String, Map<String, String>> e : raw.entrySet()) {
            String pn = e.getKey();
            String cn = e.getValue().get("company_name");
            String ev = e.getValue().get("environment");
            if (cn != null && ev != null) {
                grouped.computeIfAbsent(cn, CompanyProfile::new);
                grouped.get(cn).addEnvironment(ev.toUpperCase());
                grouped.get(cn).addProfile(pn);
            }
        }
        return new ArrayList<>(grouped.values());
    }
}

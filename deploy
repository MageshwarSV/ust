package com.healthproof.intplus.awscost.awsDev;
import com.healthproof.intplus.awscost.Model;
import com.healthproof.intplus.awscost.util.ExcelMapper;
import org.springframework.stereotype.Service;
import software.amazon.awssdk.auth.credentials.ProfileCredentialsProvider;
import software.amazon.awssdk.http.SdkHttpConfigurationOption;
import software.amazon.awssdk.http.apache.ApacheHttpClient;
import software.amazon.awssdk.services.costexplorer.CostExplorerClient;
import software.amazon.awssdk.services.costexplorer.model.*;
import software.amazon.awssdk.thirdparty.jackson.core.JsonProcessingException;
import software.amazon.awssdk.utils.AttributeMap;
import java.math.BigDecimal;
import java.math.RoundingMode;
import java.util.List;
import java.util.Map;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import static com.healthproof.intplus.awscost.util.DateUtil.getCurrentDate;
import static com.healthproof.intplus.awscost.util.DateUtil.getPreviousDate;
@Service
public class CostExplorerDev {
    private CostExplorerClient caClient;
    private Model model;
    private List<Map<String, Object>> rawQueriesData;
    private String startDate;
    private String endDate;
    public Model getModel() { return model; }
    public List<Map<String, Object>> getRawQueriesData() { return rawQueriesData; }
    public void start(String profileName, String environment, String startDate, String endDate) throws Exception {
        this.rawQueriesData = new ArrayList<>();
        this.startDate = startDate;
        this.endDate = endDate;
        init(profileName);
        getH4andH5(); getR12Values(); getNoTagAndCloudWatch(); calculateCommonService(); getRow13Values();
        System.out.println("********----->: Profile=" + profileName + " | Env=" + environment);
        model.printR12(); model.printR13(); model.printH4H5(); model.printR14();
    }
    private void init(String profileName) throws JsonProcessingException {
        this.model = new Model();
        caClient = CostExplorerClient.builder()
                .credentialsProvider(ProfileCredentialsProvider.create(profileName))
                .region(software.amazon.awssdk.regions.Region.US_EAST_1)
                .httpClient(ApacheHttpClient.builder().buildWithDefaults(AttributeMap.builder()
                        .put(SdkHttpConfigurationOption.TRUST_ALL_CERTIFICATES, Boolean.TRUE).build()))
                .build();
    }
    public void getH4andH5() {
        GetCostAndUsageRequest req = GetCostAndUsageRequest.builder()
                .timePeriod(DateInterval.builder().start(this.startDate).end(this.endDate).build())
                .granularity(Granularity.MONTHLY).metrics("NetAmortizedCost")
                .groupBy(GroupDefinition.builder().type(GroupDefinitionType.DIMENSION).key("RECORD_TYPE").build()).build();
        GetCostAndUsageResponse res = caClient.getCostAndUsage(req);
        recordRawResponse("H4_H5", res);
        res.resultsByTime().forEach(r -> r.groups().forEach(g ->
                g.metrics().forEach((k, v) -> model.getModelMapH4H5().put(g.keys().get(0), v.amount()))));
    }
    public void getR12Values() throws JsonProcessingException {
        Expression ex = Expression.builder().not(Expression.builder().dimensions(DimensionValues.builder()
                .key(Dimension.RECORD_TYPE).values("Enterprise Discount Program Discount","SavingsPlanCoveredUsage").build()).build()).build();
        GetCostAndUsageRequest req = GetCostAndUsageRequest.builder()
                .timePeriod(DateInterval.builder().start(this.startDate).end(this.endDate).build())
                .granularity(Granularity.MONTHLY).metrics("NetAmortizedCost").filter(ex)
                .groupBy(GroupDefinition.builder().type(GroupDefinitionType.TAG).key("Product").build()).build();
        GetCostAndUsageResponse res = caClient.getCostAndUsage(req);
        recordRawResponse("R12", res);
        res.resultsByTime().forEach(r -> r.groups().forEach(g ->
                g.metrics().forEach((k, v) -> model.getModelMapR12().put(g.keys().get(0), v.amount()))));
    }
    public void getNoTagAndCloudWatch() {
        Expression ex = Expression.builder().and(
                Expression.builder().not(Expression.builder().dimensions(DimensionValues.builder()
                        .key(Dimension.RECORD_TYPE).values("Enterprise Discount Program Discount","SavingsPlanCoveredUsage").build()).build()).build(),
                Expression.builder().tags(TagValues.builder().key("Product").values("").build()).build()).build();
        GetCostAndUsageRequest req = GetCostAndUsageRequest.builder()
                .timePeriod(DateInterval.builder().start(this.startDate).end(this.endDate).build())
                .granularity(Granularity.MONTHLY).metrics("NetAmortizedCost").filter(ex)
                .groupBy(GroupDefinition.builder().type(GroupDefinitionType.DIMENSION).key("SERVICE").build()).build();
        GetCostAndUsageResponse res = caClient.getCostAndUsage(req);
        recordRawResponse("R14", res);
        res.resultsByTime().forEach(r -> r.groups().forEach(g ->
                g.metrics().forEach((k, v) -> model.getModelMapR14().put(g.keys().get(0), v.amount()))));
    }
    public void getRow13Values() {
        Expression ex = Expression.builder().dimensions(DimensionValues.builder().key(Dimension.RECORD_TYPE)
                .values("Enterprise Discount Program Discount","SavingsPlanCoveredUsage").build()).build();
        GetCostAndUsageRequest req = GetCostAndUsageRequest.builder()
                .timePeriod(DateInterval.builder().start(this.startDate).end(this.endDate).build())
                .granularity(Granularity.MONTHLY).metrics("NetAmortizedCost").filter(ex)
                .groupBy(GroupDefinition.builder().type(GroupDefinitionType.TAG).key("Product").build()).build();
        GetCostAndUsageResponse res = caClient.getCostAndUsage(req);
        recordRawResponse("R13", res);
        res.resultsByTime().forEach(r -> r.groups().forEach(g ->
                g.metrics().forEach((k, v) -> model.getModelMapR13().put(g.keys().get(0), v.amount()))));
    }
    private void calculateCommonService() {
        double common = new BigDecimal(model.getModelMapR12().get(ExcelMapper.COMMON).toString()).setScale(2,RoundingMode.HALF_UP).doubleValue();
        double total = new BigDecimal(model.getModelMapR12().get(ExcelMapper.NO_KEY_PRODUCT).toString()).setScale(2,RoundingMode.HALF_UP).doubleValue();
        double ec2 = total - new BigDecimal(model.getModelMapR14().get(ExcelMapper.Y12).toString()).setScale(2,RoundingMode.HALF_UP).doubleValue() + common;
        model.getModelMapR14().put(ExcelMapper.W12, String.valueOf(ec2));
    }
    private void recordRawResponse(String queryName, GetCostAndUsageResponse response) {
        Map<String, Object> queryRecord = new LinkedHashMap<>();
        queryRecord.put("queryType", queryName);
        List<Map<String, Object>> results = new ArrayList<>();
        if (response != null && response.resultsByTime() != null) {
            for (ResultByTime result : response.resultsByTime()) {
                Map<String, Object> timeRecord = new LinkedHashMap<>();
                timeRecord.put("timePeriod", Map.of("start", result.timePeriod().start(), "end", result.timePeriod().end()));
                timeRecord.put("estimated", result.estimated());
                List<Map<String, Object>> groups = new ArrayList<>();
                if (result.groups() != null) {
                    for (Group group : result.groups()) {
                        Map<String, Object> groupRecord = new LinkedHashMap<>();
                        groupRecord.put("keys", group.keys());
                        Map<String, Map<String, String>> metrics = new LinkedHashMap<>();
                        if (group.metrics() != null) {
                            group.metrics().forEach((k, v) -> {
                                metrics.put(k, Map.of("amount", v.amount(), "unit", v.unit()));
                            });
                        }
                        groupRecord.put("metrics", metrics);
                        groups.add(groupRecord);
                    }
                }
                timeRecord.put("groups", groups);
                results.add(timeRecord);
            }
        }
        queryRecord.put("results", results);
        rawQueriesData.add(queryRecord);
    }
}

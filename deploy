package com.healthproof.intplus.awscost.excel;
import com.healthproof.intplus.awscost.Model;
import com.healthproof.intplus.awscost.util.ExcelMapper;
import org.apache.poi.ss.usermodel.*;
import org.apache.poi.ss.util.CellReference;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.springframework.beans.factory.annotation.Value;
import java.io.*;
import java.math.*;
import java.nio.file.*;
import java.util.*;
import static com.healthproof.intplus.awscost.util.DateUtil.getRequiredDate;

public abstract class BaseExcelProcessor {
    @Value("${excel.template.file.path}") protected String templateFilePath;
    @Value("${excel.template.file.name}") protected String templateFileName;
    @Value("${excel.input.file.path}") protected String inputFilePath;
    @Value("${excel.input.file.name}") protected String inputFileName;
    @Value("${excel.output.file.path}") protected String outFilePath;
    protected Workbook workbook; protected Sheet sheet; protected String fileName;
    
    public void start(String companyName, List<String> environments, List<Model> models, String monthYearName) throws IOException {
        String basePattern = "USTHP_" + companyName + "_AWS_SERVICE_COST_" + monthYearName + "-V";
        File outputDir = new File(outFilePath);
        if (!outputDir.exists()) outputDir.mkdirs();
        File[] existing = outputDir.listFiles((d, n) -> n.startsWith(basePattern) && n.endsWith(ExcelMapper.FILE_EXTENSION));
        int version = 1;
        if (existing != null) {
            for (File f : existing) {
                try {
                    int x = Integer.parseInt(f.getName().substring(basePattern.length(), f.getName().length() - ExcelMapper.FILE_EXTENSION.length()));
                    if (x >= version) version = x + 1;
                } catch (Exception ignored) {}
            }
        }
        this.fileName = basePattern + version + ExcelMapper.FILE_EXTENSION;
        
        String tplPath = templateFilePath + File.separator + companyName.toLowerCase() + "_template.xlsx";
        File tplFile = new File(tplPath);
        if (!tplFile.exists()) tplPath = templateFilePath + File.separator + templateFileName + ExcelMapper.FILE_EXTENSION;
        try (FileInputStream fis = new FileInputStream(tplPath)) { this.workbook = new XSSFWorkbook(fis); }

        for (int i = 0; i < environments.size(); i++) {
            String env = environments.get(i); Model model = models.get(i);
            String sheetName = companyName + "-" + env;
            sheet = workbook.getSheet(sheetName);
            if (sheet == null) {
                for(int s=0; s<workbook.getNumberOfSheets(); s++){
                    if(workbook.getSheetName(s).equalsIgnoreCase(sheetName)){ sheet = workbook.getSheetAt(s); break; }
                }
            }
            if (sheet == null) { System.out.println("Sheet not found: "+sheetName); continue; }
            
            initSheet(companyName, env);
            writeH4H5(model.getModelMapH4H5(), companyName, env);
            writeR12(model.getModelMapR12(), companyName, env);
            writeR14(model.getModelMapR14(), companyName, env);
            writeR13(model.getModelMapR13(), companyName, env);
            writeESPCost();
        }
        writeExcel(); copyFileToInputDirectory();
    }
    
    protected boolean check(String c,String e){return sheet!=null&&sheet.getSheetName().equalsIgnoreCase(c+"-"+e);}
    
    protected void initSheet(String c,String e){
        if(!check(c,e))return;
        setStr("H3",getRequiredDate());setNum("H4",0);setNum("H5",0);setNum("H6",0);
        for(int i=1;i<27;i++){
            if(sheet.getRow(11)!=null && sheet.getRow(11).getCell(i)!=null) sheet.getRow(11).getCell(i).setCellValue(0);
            if(sheet.getRow(12)!=null && sheet.getRow(12).getCell(i)!=null) sheet.getRow(12).getCell(i).setCellValue(0);
            if(sheet.getRow(13)!=null && sheet.getRow(13).getCell(i)!=null) sheet.getRow(13).getCell(i).setCellValue(0);
        }
    }
    
    protected void writeH4H5(Map m,String c,String e){
        if(!check(c,e))return;
        double tax = bd(val(m,"Tax"));
        setNum("H4", bd(val(m,ExcelMapper.H4)) + tax);
        setNum("H5", bd(val(m,ExcelMapper.H5)));
    }
    
    protected abstract void writeR12(Map<String,String> m,String c,String e);
    protected abstract void writeR14(Map<String,String> m,String c,String e);
    protected abstract void writeR13(Map<String,String> m,String c,String e);
    
    protected void writeESPCost(){setNum("H6",0);setNum("AA12",0);}
    protected double bd(String v){return new BigDecimal(v).setScale(2,RoundingMode.HALF_UP).doubleValue();}
    
    protected String val(Map<String,String> m,String k){
        if(m.get(k)!=null) return m.get(k).toString();
        String fallbackNoHyphen = k.replaceAll("-(\\d+)$", "$1"); 
        if(m.get(fallbackNoHyphen)!=null) return m.get(fallbackNoHyphen).toString();
        String fallbackWithHyphen = k.replaceAll("(?<!-)(\\d+)$", "-$1");
        if(m.get(fallbackWithHyphen)!=null) return m.get(fallbackWithHyphen).toString();
        return "0";
    }
    
    protected void setNum(String ref, double val) {
        Cell c = getCell(ref); if (c != null) { c.setCellValue(val); }
    }
    protected void setStr(String ref, String val) {
        Cell c = getCell(ref); if (c != null) c.setCellValue(val);
    }
    protected Cell getCell(String ref) {
        CellReference cr = new CellReference(ref);
        Row r = sheet.getRow(cr.getRow());
        if (r == null) r = sheet.createRow(cr.getRow());
        Cell c = r.getCell(cr.getCol());
        if (c == null) c = r.createCell(cr.getCol());
        return c;
    }
    
    protected void writeExcel() throws IOException {
        workbook.setForceFormulaRecalculation(true);
        try (FileOutputStream fos = new FileOutputStream(outFilePath + File.separator + fileName)) { 
            workbook.write(fos); workbook.close(); 
        }
    }
    
    protected void copyFileToInputDirectory() throws IOException {
        Path dest = Paths.get(inputFilePath + File.separator + inputFileName + ExcelMapper.FILE_EXTENSION);
        if (Files.notExists(dest)) Files.createFile(dest);
        Files.copy(Paths.get(outFilePath + File.separator + fileName), dest, StandardCopyOption.REPLACE_EXISTING);
    }
    public String getFileName() { return fileName; }
}
